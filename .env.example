# ═══════════════════════════════════════════════════════════════
# Agentic AI Research Copilot — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# LLM — Ollama (default, local, free)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434

# LLM — Google Gemini (optional, set key to enable)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# RAG
CHROMA_DB_PATH=./chroma_db
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# Memory
MEMORY_SIZE=3

# Timeout (seconds)
LLM_TIMEOUT=60
